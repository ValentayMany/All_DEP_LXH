RewriteEngine On

# API -> PHP
RewriteRule ^api(?:/(.*))?$ api/index.php [QSA,L]

# Static files from public/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/$1 [L]

# SPA fallback
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ public/index.html [L]
